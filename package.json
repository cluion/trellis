{
  "name": "trellis-monorepo",
  "private": true,
  "description": "Trellis — 現代化、無頭式、插件導向的資料表格庫",
  "scripts": {
    "build": "pnpm -r --stream run build",
    "test": "pnpm -r --stream run test",
    "test:watch": "pnpm -r --parallel run test:watch",
    "clean": "pnpm -r run clean && rm -rf node_modules",
    "prepare": "husky"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "packageManager": "pnpm@9.15.4",
  "devDependencies": {
    "husky": "^9.1.7"
  }
}
