{
  "name": "@trellisjs/server-prisma",
  "version": "0.1.0",
  "description": "Prisma ORM 轉接器 — 一行搞定 Trellis 查詢",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": { "types": "./dist/index.d.ts", "default": "./dist/index.js" },
      "require": { "types": "./dist/index.d.cts", "default": "./dist/index.cjs" }
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "@trellisjs/server": "workspace:*",
    "@prisma/client": ">=5.0.0"
  },
  "devDependencies": {
    "@trellisjs/server": "workspace:*",
    "tsup": "^8.4.0",
    "typescript": "^5.7.0",
    "vitest": "^3.1.0"
  },
  "license": "MIT",
  "sideEffects": false
}
