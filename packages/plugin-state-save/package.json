{
  "name": "@trellisjs/plugin-state-save",
  "version": "1.0.0",
  "description": "Trellis 狀態保存插件 — 自動將表格 UI 狀態持久化到瀏覽器 storage，頁面重載後恢復",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "@trellisjs/core": "workspace:^"
  },
  "devDependencies": {
    "@trellisjs/core": "workspace:*",
    "@trellisjs/plugin-sort": "workspace:*",
    "@trellisjs/plugin-pagination": "workspace:*",
    "@trellisjs/plugin-filter": "workspace:*",
    "@trellisjs/plugin-column-visibility": "workspace:*",
    "@trellisjs/plugin-row-expansion": "workspace:*",
    "@trellisjs/plugin-column-pinning": "workspace:*",
    "@trellisjs/plugin-column-resizing": "workspace:*",
    "tsup": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/cluion/trellis.git",
    "directory": "packages/plugin-state-save"
  },
  "license": "MIT",
  "sideEffects": false
}
