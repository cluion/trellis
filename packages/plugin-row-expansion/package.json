{
  "name": "@trellisjs/plugin-row-expansion",
  "version": "0.1.0",
  "description": "Trellis 行展開插件 — 支援 accordion 和 multi 展開模式",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "@trellisjs/core": "workspace:^"
  },
  "devDependencies": {
    "@trellisjs/core": "workspace:*",
    "@trellisjs/plugin-sort": "workspace:*",
    "@trellisjs/plugin-filter": "workspace:*",
    "@trellisjs/plugin-pagination": "workspace:*",
    "tsup": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/cluion/trellis.git",
    "directory": "packages/plugin-row-expansion"
  },
  "license": "MIT",
  "sideEffects": false
}
