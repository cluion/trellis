{
  "name": "@trellisjs/plugin-selection",
  "version": "2.0.0",
  "description": "Trellis 行選取插件 — 單選、全選、Shift 範圍選",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "@trellisjs/core": "workspace:*"
  },
  "devDependencies": {
    "@trellisjs/core": "workspace:*",
    "tsup": "^8.4.0",
    "typescript": "^5.7.0",
    "vitest": "^3.1.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/cluion/trellis.git",
    "directory": "packages/plugin-selection"
  },
  "license": "MIT",
  "sideEffects": false
}
